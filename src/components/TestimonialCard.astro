---
interface Props {
  testimonial: {
    name: string;
    location: string;
    rating: number;
    text: string;
    project: string;
    image: string;
  };
}

const { testimonial } = Astro.props;
const initials = testimonial.name
  .split(' ')
  .map(n => n[0])
  .join('')
  .toUpperCase();
---

<div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm hover:shadow-md transition-shadow duration-300">
  <!-- Quote Icon -->
  <div class="text-brand-400 mb-4">
    <svg class="w-10 h-10 opacity-50" fill="currentColor" viewBox="0 0 32 32">
      <path d="M10 8c-3.3 0-6 2.7-6 6v10h10V14H8c0-1.1.9-2 2-2V8zm12 0c-3.3 0-6 2.7-6 6v10h10V14h-6c0-1.1.9-2 2-2V8z"/>
    </svg>
  </div>
  
  <!-- Stars -->
  <div class="flex gap-0.5 mb-4">
    {Array.from({ length: 5 }, (_, i) => (
      <svg 
        class={`w-5 h-5 ${i < testimonial.rating ? 'text-warm-400' : 'text-stone-200'}`} 
        fill="currentColor" 
        viewBox="0 0 20 20"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
    ))}
  </div>
  
  <!-- Text -->
  <p class="text-stone-600 leading-relaxed mb-6 italic">
    "{testimonial.text}"
  </p>
  
  <!-- Author -->
  <div class="flex items-center gap-4 pt-4 border-t border-stone-100">
    {testimonial.image ? (
      <img 
        src={testimonial.image} 
        alt={testimonial.name} 
        class="w-12 h-12 rounded-full object-cover"
        loading="lazy"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
    ) : null}
    <div 
      class={`w-12 h-12 rounded-full bg-brand-100 text-brand-600 font-semibold flex items-center justify-center ${testimonial.image ? 'hidden' : 'flex'}`}
      style={testimonial.image ? 'display: none;' : ''}
    >
      {initials}
    </div>
    <div>
      <h4 class="font-semibold text-neutral-900">{testimonial.name}</h4>
      <p class="text-sm text-stone-500">{testimonial.location}</p>
      <p class="text-xs text-brand-600 font-medium mt-0.5">{testimonial.project}</p>
    </div>
  </div>
</div>