---
import { formatPrice, getStockLabel } from '../utils/formatters';

interface Props {
  product: {
    id: number;
    name: string;
    slug: string;
    category: string;
    price: string;
    displayPrice: boolean;
    stock: string;
    thumbnail: string;
    images: string[];
    description: string;
    tags: string[];
  };
}

const { product } = Astro.props;
const stockInfo = getStockLabel(product.stock);
const numericPrice = parseFloat(product.price.replace(/,/g, ''));
---

<a 
  href={`/products/${product.slug}`} 
  class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex flex-col"
>
  <!-- Image Container -->
  <div class="relative aspect-[4/3] overflow-hidden bg-stone-100">
    <img 
      src={product.thumbnail} 
      alt={product.name} 
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      decoding="async"
      onerror="this.src='/src/assets/images/placeholder.png'"
    />
    
    <!-- Stock Badge -->
    <span class={`absolute top-3 left-3 px-2.5 py-1 rounded-full text-xs font-medium ${stockInfo.color}`}>
      {stockInfo.text}
    </span>
    
    <!-- Overlay on hover -->
    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
      <span class="bg-white text-neutral-900 px-4 py-2 rounded-lg text-sm font-medium transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
        View Details
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="p-5 flex-1 flex flex-col">
    <span class="text-xs text-brand-600 font-medium uppercase tracking-wider mb-2 block">
      {product.category.replace('-', ' ')}
    </span>
    
    <h3 class="font-serif text-lg font-semibold text-neutral-900 mb-1 line-clamp-2 group-hover:text-brand-600 transition-colors flex-1">
      {product.name}
    </h3>
    
    <div class="mt-2 flex items-center gap-2">
      {product.displayPrice ? (
        <span class="text-xl font-bold text-neutral-900">{formatPrice(product.price)}</span>
      ) : (
        <span class="text-sm text-brand-600 font-medium">Price on Request</span>
      )}
    </div>
    
    <!-- Tags -->
    {product.tags && product.tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-3">
        {product.tags.slice(0, 3).map(tag => (
          <span class="text-[10px] bg-stone-100 text-stone-600 px-2 py-0.5 rounded-full uppercase tracking-wide">
            {tag.replace('-', ' ')}
          </span>
        ))}
      </div>
    )}
    <!-- Add To Cart Button -->
    <button class="mt-4 bg-brand-600 text-white py-2 px-4 rounded-lg hover:bg-brand-700 transition-colors focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2">
      Add to Cart
    </button>
  </div>
</a>