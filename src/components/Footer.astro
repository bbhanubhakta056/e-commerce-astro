---
import { navigation } from '../data/navigation';
import { siteConfig } from '../data/siteConfig';
---

<footer class="bg-neutral-900 text-stone-300 pt-20 pb-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Top Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-6">
          <span class="text-3xl">🏠</span>
          <div>
            <h2 class="font-serif text-xl font-bold text-white">{siteConfig.name}</h2>
            <p class="text-xs text-stone-500 tracking-wider uppercase">Curated Interiors</p>
          </div>
        </a>
        <p class="text-stone-400 leading-relaxed mb-6">
          Premium interior products and design consultation. Transforming spaces across {siteConfig.address.city} since 2010.
        </p>
        <div class="flex gap-3">
          <a href={siteConfig.social.instagram} class="w-10 h-10 rounded-full bg-neutral-800 flex items-center justify-center hover:bg-brand-600 transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href={siteConfig.social.facebook} class="w-10 h-10 rounded-full bg-neutral-800 flex items-center justify-center hover:bg-brand-600 transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Products Column -->
      <div>
        <h3 class="text-white font-semibold mb-6 text-lg">Products</h3>
        <ul class="space-y-3">
          {navigation.footer.products.map(link => (
            <li>
              <a href={link.href} class="text-stone-400 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services Column -->
      <div>
        <h3 class="text-white font-semibold mb-6 text-lg">Services</h3>
        <ul class="space-y-3">
          {navigation.footer.services.map(link => (
            <li>
              <a href={link.href} class="text-stone-400 hover:text-white transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="text-white font-semibold mb-6 text-lg">Contact Us</h3>
        <ul class="space-y-4 text-sm text-stone-400">
          <li class="flex gap-3">
            <span class="text-lg">📍</span>
            <span>{siteConfig.address.line1}, {siteConfig.address.line2}<br/>{siteConfig.address.city}, {siteConfig.address.state} - {siteConfig.address.pincode}</span>
          </li>
          <li class="flex gap-3">
            <span class="text-lg">📞</span>
            <a href={`tel:${siteConfig.phone}`} class="hover:text-white transition-colors">{siteConfig.phone}</a>
          </li>
          <li class="flex gap-3">
            <span class="text-lg">✉️</span>
            <a href={`mailto:${siteConfig.email}`} class="hover:text-white transition-colors">{siteConfig.email}</a>
          </li>
          <li class="flex gap-3">
            <span class="text-lg">🕐</span>
            <span>
              Mon-Sat: {siteConfig.timing.weekdays}<br/>
              Sun: {siteConfig.timing.sunday}
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-neutral-800 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-stone-500 text-sm">
        &copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="/privacy" class="text-stone-500 hover:text-white text-sm transition-colors">Privacy Policy</a>
        <a href="/terms" class="text-stone-500 hover:text-white text-sm transition-colors">Terms of Service</a>
      </div>
    </div>

  </div>
</footer>