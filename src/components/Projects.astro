---
import Reveal from "./Reveal.vue";

const projects = [
  {
    title: "Modern Living Room",
    category: "Residential",
    image:
      "https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=2070&auto=format&fit=crop"
  },

  {
    title: "Minimal Workspace",
    category: "Commercial",
    image:
      "https://images.unsplash.com/photo-1497366754035-f200968a6e72?q=80&w=2070&auto=format&fit=crop"
  },

  {
    title: "Luxury Bedroom",
    category: "Interior Styling",
    image:
      "https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?q=80&w=2070&auto=format&fit=crop"
  }
];
---

<section
  id="projects"
  class="relative py-32 bg-black"
>

  <div class="max-w-7xl mx-auto px-6">

    <!-- Heading -->
    <div class="mb-20">

      <p class="uppercase tracking-[0.4em] text-zinc-500 mb-4">
        Featured Projects
      </p>

      <h2 class="text-5xl md:text-7xl font-light leading-tight max-w-3xl">
        Spaces crafted
        with precision
        and emotion.
      </h2>

    </div>

    <!-- Grid -->
    <div class="grid md:grid-cols-2 gap-10">

      {projects.map((project, index) => (

        <Reveal client:visible>
            <article
            class={`group relative overflow-hidden rounded-[2rem]
            ${index === 1 ? "md:translate-y-24" : ""}
            `}
            >

            <!-- Image -->
            <div class="overflow-hidden will-change-transform">

                <img
                src={project.image}
                alt={project.title}
                class="w-full h-[750px] object-cover
                transition duration-700
                group-hover:scale-110
                group-hover:rotate-1"
                />

            </div>

            <!-- Overlay -->
            <div
                class="absolute inset-0 bg-gradient-to-t
                from-black/80 via-black/10 to-transparent"
            ></div>

            <!-- Content -->
            <div class="absolute bottom-0 left-0 p-8">

                <p class="text-sm uppercase tracking-[0.3em] text-zinc-300 mb-3">
                {project.category}
                </p>

                <h3 class="text-3xl md:text-4xl font-light">
                {project.title}
                </h3>

            </div>

            </article>
        </Reveal>

      ))}

    </div>

  </div>

</section>