---
import { navigation } from '../data/navigation';
import { siteConfig } from '../data/siteConfig';

const currentPath = Astro.url.pathname;
---

<header class="bg-white/95 backdrop-blur-sm shadow-sm sticky top-0 z-50 border-b border-stone-200">
  <!-- Announcement Bar -->
  <div class="bg-brand-600 text-white text-xs md:text-sm py-2 text-center">
    <p>🎉 Free Shipping on orders above रु. 5,000 | Visit our showroom in {siteConfig.address.city}</p>
  </div>

  <!-- Main Header -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <span class="text-3xl md:text-4xl transition-transform group-hover:scale-110">🏠</span>
        <div class="hidden sm:block">
          <h1 class="font-serif text-xl md:text-2xl font-bold text-neutral-900 leading-tight">
            {siteConfig.name}
          </h1>
          <p class="text-[10px] text-stone-500 tracking-[0.3em] uppercase">
            Curated Interiors
          </p>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        {navigation.main.map(item => {
          const isActive = currentPath === item.href || 
            (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a 
              href={item.href} 
              class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200
                ${isActive 
                  ? 'text-brand-600 bg-brand-50' 
                  : 'text-stone-600 hover:text-brand-600 hover:bg-stone-50'
                }`}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <!-- Right side: CTA + Mobile menu -->
      <div class="flex items-center gap-4">
        <a 
          href="/contact" 
          class="hidden md:inline-flex items-center gap-2 bg-brand-600 text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-brand-700 transition-all duration-200 shadow-sm hover:shadow-md"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Get Free Quote
        </a>

        <!-- Mobile menu button -->
        <button 
          id="mobile-menu-btn" 
          class="lg:hidden p-2 rounded-lg text-stone-700 hover:bg-stone-100 transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg id="menu-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-stone-200 bg-white">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      {navigation.main.map(item => {
        const isActive = currentPath === item.href;
        return (
          <a 
            href={item.href} 
            class={`block px-4 py-3 rounded-lg text-base font-medium transition-colors
              ${isActive 
                ? 'text-brand-600 bg-brand-50' 
                : 'text-stone-600 hover:text-brand-600 hover:bg-stone-50'
              }`}
          >
            {item.label}
          </a>
        );
      })}
      <a 
        href="/contact" 
        class="block mt-2 px-4 py-3 rounded-lg bg-brand-600 text-white text-center font-semibold hover:bg-brand-700 transition-colors"
      >
        Get Free Quote
      </a>
    </div>
  </div>
</header>