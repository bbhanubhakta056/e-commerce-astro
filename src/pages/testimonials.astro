---
import BaseLayout from '../layouts/BaseLayout.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { testimonials } from '../data/testimonials';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout 
  title="Client Reviews & Testimonials"
  description="Read what our clients say about Elegance Interiors. Trusted by 500+ homeowners and architects in Bangalore."
>
  
  <!-- Hero -->
  <section class="bg-stone-100 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-neutral-900 mb-4">Client Testimonials</h1>
      <p class="text-stone-600 text-lg max-w-2xl mx-auto">
        Don't just take our word for it. Here's what our clients have to say.
      </p>
      
      <!-- Overall Rating -->
      <div class="flex items-center justify-center gap-4 mt-6">
        <div class="flex gap-1">
          {[1,2,3,4,5].map(i => (
            <svg class="w-6 h-6 text-warm-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="text-2xl font-bold text-neutral-900">4.8</span>
        <span class="text-stone-500">({testimonials.length} reviews)</span>
      </div>
    </div>
  </section>

  <!-- Testimonials Grid -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map(testimonial => (
          <TestimonialCard testimonial={testimonial} />
        ))}
      </div>
    </div>
  </section>

  <!-- Leave Review CTA -->
  <section class="py-16 bg-brand-600">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-serif text-3xl font-bold text-white mb-4">Loved Our Products?</h2>
      <p class="text-brand-100 text-lg mb-8">Share your experience and help others discover great design</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="https://g.page/r/your-google-review-link" 
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-white text-neutral-900 px-8 py-4 rounded-lg font-semibold hover:bg-stone-100 transition-all"
        >
          ⭐ Leave a Google Review
        </a>
        <a 
          href="/contact" 
          class="inline-flex items-center gap-2 bg-brand-700 text-white px-8 py-4 rounded-lg font-semibold hover:bg-brand-800 transition-all"
        >
          Share Feedback Directly
        </a>
      </div>
    </div>
  </section>

</BaseLayout>