---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ContactForm from '../../components/ContactForm.astro';
import { products } from '../../data/products';
import { formatPrice, getStockLabel } from '../../utils/formatters';
import { getRelatedProducts } from '../../utils/filters';
import { siteConfig } from '../../data/siteConfig';

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
const relatedProducts = getRelatedProducts(product, products, 4);
const stockInfo = getStockLabel(product.stock);
const numericPrice = parseFloat(product.price.replace(/,/g, ''));
const inStock = product.stock === 'in-stock' || product.stock === 'limited-stock';
---

<BaseLayout 
  title={product.name}
  description={product.description}
  image={product.images[0]}
>
  
  <!-- Breadcrumb -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <nav class="flex items-center gap-2 text-sm text-stone-500">
      <a href="/" class="hover:text-brand-600">Home</a>
      <span>/</span>
      <a href="/products" class="hover:text-brand-600">Products</a>
      <span>/</span>
      <a href={`/products?category=${product.category}`} class="hover:text-brand-600 capitalize">
        {product.category.replace('-', ' ')}
      </a>
      <span>/</span>
      <span class="text-stone-800">{product.name}</span>
    </nav>
  </div>

  <!-- Product Detail -->
  <section class="py-8 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        
        {/* Image Gallery */}
        <div class="space-y-4">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-stone-100">
            <img 
              id="main-image"
              src={product.images[0]} 
              alt={product.name}
              class="w-full h-full object-cover"
              onerror="this.src='/images/placeholder.jpg'"
            />
          </div>
          
          {product.images.length > 1 && (
            <div class="flex gap-3 overflow-x-auto pb-2">
              {product.images.map((img, index) => (
                <button 
                  class="w-20 h-20 rounded-lg overflow-hidden border-2 flex-shrink-0 hover:border-brand-500 transition-colors focus:outline-none"
                  class:border-brand-500={index === 0}
                  class:border-transparent={index !== 0}
                  onclick={`document.getElementById('main-image').src='${img}'; this.parentElement.querySelectorAll('button').forEach(b => b.classList.remove('border-brand-500')); this.classList.add('border-brand-500');`}
                >
                  <img src={img} alt={`${product.name} view ${index + 1}`} class="w-full h-full object-cover" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </div>

        {/* Product Info */}
        <div class="space-y-6">
          <div>
            <span class="text-sm text-brand-600 font-medium uppercase tracking-wider">
              {product.category.replace('-', ' ')}
            </span>
            <h1 class="font-serif text-3xl md:text-4xl font-bold text-neutral-900 mt-1">
              {product.name}
            </h1>
          </div>

          {/* Price */}
          <div class="flex items-center gap-4">
            {product.displayPrice ? (
              <>
                <span class="text-3xl font-bold text-neutral-900">
                  {formatPrice(product.price)}
                </span>
                <span class="text-sm text-stone-500">inclusive of all taxes</span>
              </>
            ) : (
              <span class="text-brand-600 font-semibold text-lg">Price on Request</span>
            )}
            <span class={`px-3 py-1 rounded-full text-xs font-medium ${stockInfo.color}`}>
              {stockInfo.text}
            </span>
          </div>

          {/* Description */}
          <p class="text-stone-600 leading-relaxed">{product.description}</p>

          {/* Details Grid */}
          <div class="grid grid-cols-2 gap-4 py-4 border-t border-stone-200">
            <div>
              <span class="text-sm text-stone-500">Dimensions</span>
              <p class="font-medium text-neutral-900">{product.dimensions}</p>
            </div>
            <div>
              <span class="text-sm text-stone-500">Material</span>
              <p class="font-medium text-neutral-900">{product.material}</p>
            </div>
          </div>

          {/* Color Options */}
          {product.colors && product.colors.length > 0 && (
            <div>
              <span class="text-sm text-stone-500 block mb-2">Available Colors</span>
              <div class="flex flex-wrap gap-2">
                {product.colors.map(color => (
                  <span class="px-3 py-1.5 bg-stone-100 rounded-full text-sm text-neutral-700 border border-stone-200">
                    {color}
                  </span>
                ))}
              </div>
            </div>
          )}

          {/* Highlights */}
          <div class="bg-stone-50 rounded-xl p-5">
            <h4 class="font-semibold text-neutral-900 mb-3">Highlights</h4>
            <ul class="space-y-2">
              {product.highlights.map(highlight => (
                <li class="flex items-start gap-2 text-sm text-stone-700">
                  <svg class="w-5 h-5 text-brand-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {highlight}
                </li>
              ))}
            </ul>
          </div>

          {/* ADD TO CART BUTTONS (NEW E-COMMERCE SECTION) */}
          <div class="pt-4 space-y-3">
            {inStock && product.displayPrice ? (
              <>
                <!-- Quantity Selector + Add to Cart -->
                <div class="flex items-center gap-4">
                  <label class="text-sm font-medium text-stone-700">Qty:</label>
                  <div class="flex items-center border border-stone-300 rounded-lg">
                    <button 
                      type="button"
                      class="px-3 py-2 hover:bg-stone-100 transition-colors text-stone-600"
                      onclick="const qty = document.getElementById('product-qty'); if(qty.value > 1) qty.value--; updateBuyButton()"
                    >−</button>
                    <input 
                      type="number" 
                      id="product-qty" 
                      value="1" 
                      min="1" 
                      max="10"
                      class="w-14 text-center border-x border-stone-300 py-2 text-sm focus:outline-none"
                      onchange="updateBuyButton()"
                    />
                    <button 
                      type="button"
                      class="px-3 py-2 hover:bg-stone-100 transition-colors text-stone-600"
                      onclick="const qty = document.getElementById('product-qty'); if(qty.value < 10) qty.value++; updateBuyButton()"
                    >+</button>
                  </div>
                </div>

                <!-- Add to Cart -->
                <button 
                  id="add-to-cart-btn"
                  class="snipcart-add-item w-full bg-brand-600 text-white py-4 rounded-lg font-semibold hover:bg-brand-700 transition-all hover:shadow-lg flex items-center justify-center gap-2 text-lg"
                  data-item-id={product.id}
                  data-item-name={product.name}
                  data-item-price={numericPrice}
                  data-item-url={`${siteConfig.site || ''}/products/${product.slug}`}
                  data-item-image={product.images[0]}
                  data-item-description={product.description}
                  data-item-max-quantity="10"
                  data-item-custom1-name="Color"
                  data-item-custom1-options={product.colors.join('|')}
                >
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                  </svg>
                  Add to Cart — {formatPrice(product.price)}
                </button>
              </>
            ) : (
              <a 
                href="#enquiry-form" 
                class="block w-full bg-brand-600 text-white text-center py-4 rounded-lg font-semibold hover:bg-brand-700 transition-all hover:shadow-lg"
              >
                Enquire About This Product
              </a>
            )}
            
            <!-- WhatsApp Quick Buy -->
            <a 
              href={`https://wa.me/${siteConfig.whatsapp.replace(/\+/g, '')}?text=Hi! I'm interested in buying: ${product.name} (${formatPrice(product.price)})`}
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full bg-green-500 text-white text-center py-3 rounded-lg font-semibold hover:bg-green-600 transition-all"
            >
              💬 Buy via WhatsApp
            </a>
          </div>

          <!-- Delivery Info -->
          <div class="bg-blue-50 rounded-xl p-4 flex gap-3 items-start">
            <span class="text-xl">🚚</span>
            <div>
              <p class="font-semibold text-blue-900 text-sm">Free Shipping</p>
              <p class="text-blue-700 text-xs">On orders above रु. 5,000. Delivery in 5-7 business days.</p>
            </div>
          </div>

          <!-- Return Policy -->
          <div class="flex gap-3 items-start text-sm text-stone-500">
            <span>🔄</span>
            <span>7-day easy returns. <a href="/returns" class="text-brand-600 underline">Learn more</a></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Enquiry Form (for non-stock or custom orders) -->
  <section id="enquiry-form" class="py-16 bg-stone-50">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-2xl font-bold text-neutral-900 text-center mb-2">
        Have Questions About This Product?
      </h2>
      <p class="text-stone-500 text-center mb-8">
        Fill the form below and our design experts will get back to you within 24 hours
      </p>
      <ContactForm productName={product.name} />
    </div>
  </section>

  {/* Related Products */}
  {relatedProducts.length > 0 && (
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-serif text-3xl font-bold text-neutral-900 text-center mb-10">
          Complete the Look
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {relatedProducts.map(rp => (
            <ProductCard product={rp} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<script>
  function updateBuyButton() {
    const qty = document.getElementById('product-qty');
    const btn = document.getElementById('add-to-cart-btn');
    if (qty && btn) {
      btn.setAttribute('data-item-quantity', qty.value);
      const price = {numericPrice};
      const total = (price * parseInt(qty.value)).toLocaleString('en-IN');
      btn.innerHTML = `
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
        Add to Cart — रु. ${total}
      `;
    }
  }

  // Initial setup
  document.addEventListener('DOMContentLoaded', updateBuyButton);
</script>