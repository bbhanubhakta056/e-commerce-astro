---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout 
  title="Visit Our Showroom - Location & Directions"
  description="Visit Elegance Interiors showroom in Indiranagar, Bangalore. View maps, timings, and get directions."
>
  
  <!-- Hero -->
  <section class="bg-stone-100 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-neutral-900 mb-4">Visit Our Showroom</h1>
      <p class="text-stone-600 text-lg max-w-2xl mx-auto">
        Experience our products in person. We're conveniently located in the heart of {siteConfig.address.city}.
      </p>
    </div>
  </section>

  <!-- Map + Info -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        
        <!-- Map (2/3 width) -->
        <div class="lg:col-span-2">
          <div class="rounded-2xl overflow-hidden shadow-sm border border-stone-200 h-[400px] lg:h-full min-h-[400px]">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d113060.50999737186!2d83.35013489981955!3d27.682038573686597!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3996864275d9755f%3A0x2b1e92d89d4bb3ae!2sButwal!5e0!3m2!1sen!2snp!4v1778814320419!5m2!1sen!2snp" 
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              title="Elegance Interiors Location"
            ></iframe>
          </div>
        </div>

        <!-- Info Sidebar (1/3 width) -->
        <div class="space-y-6">
          
          <!-- Address Card -->
          <div class="bg-stone-50 rounded-2xl p-6">
            <h3 class="font-serif text-xl font-semibold text-neutral-900 mb-4 flex items-center gap-2">
              <span>📍</span> Address
            </h3>
            <p class="text-stone-700 leading-relaxed">
              <strong>{siteConfig.name}</strong><br/>
              {siteConfig.address.line1}<br/>
              {siteConfig.address.line2}<br/>
              {siteConfig.address.city}, {siteConfig.address.state}<br/>
              PIN: {siteConfig.address.pincode}
            </p>
            <p class="text-sm text-stone-500 mt-2 flex items-center gap-1">
              <span>🚩</span> {siteConfig.address.landmark}
            </p>
            <a 
              href={`https://maps.google.com/?q=${encodeURIComponent(siteConfig.address.line1 + ' ' + siteConfig.address.city)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 mt-4 text-brand-600 font-semibold hover:text-brand-700"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Open in Google Maps
            </a>
          </div>

          <!-- Timing Card -->
          <div class="bg-stone-50 rounded-2xl p-6">
            <h3 class="font-serif text-xl font-semibold text-neutral-900 mb-4 flex items-center gap-2">
              <span>🕐</span> Working Hours
            </h3>
            <div class="space-y-2">
              <div class="flex justify-between">
                <span class="text-stone-600">Monday - Saturday</span>
                <span class="font-semibold text-neutral-900">{siteConfig.timing.weekdays}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-stone-600">Sunday</span>
                <span class="font-semibold text-neutral-900">{siteConfig.timing.sunday}</span>
              </div>
              <div class="flex justify-between pt-2 border-t border-stone-200">
                <span class="text-red-500">Weekly Off</span>
                <span class="font-semibold text-red-500">{siteConfig.timing.holiday}</span>
              </div>
            </div>
          </div>

          <!-- Contact Card -->
          <div class="bg-brand-50 rounded-2xl p-6">
            <h3 class="font-serif text-xl font-semibold text-neutral-900 mb-4 flex items-center gap-2">
              <span>📞</span> Quick Contact
            </h3>
            <a 
              href={`tel:${siteConfig.phone}`}
              class="block w-full bg-brand-600 text-white text-center py-3 rounded-lg font-semibold hover:bg-brand-700 transition-all mb-3"
            >
              Call {siteConfig.phone}
            </a>
            <a 
              href={`https://wa.me/${siteConfig.whatsapp.replace(/\+/g, '')}?text=Hi! I'm planning to visit your showroom.`}
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full bg-green-500 text-white text-center py-3 rounded-lg font-semibold hover:bg-green-600 transition-all"
            >
              WhatsApp Us
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Showroom Photos -->
  <section class="py-16 bg-stone-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-3xl font-bold text-neutral-900 text-center mb-10">Inside Our Showroom</h2>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {['bookshelf', 'sofa-main', 'table', 'rug'].map(i => (
          <div class="aspect-square rounded-2xl overflow-hidden bg-stone-200">
            <img 
              src={`/images/products/${i}.jpg`} 
              alt={`Showroom view ${i}`}
              class="w-full h-full object-cover hover:scale-110 transition-transform duration-500"
              loading="lazy"
              onerror="this.parentElement.classList.add('bg-stone-300'); this.style.display='none';"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Parking & Accessibility -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-3xl font-bold text-neutral-900 text-center mb-10">Visitor Information</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center p-6">
          <span class="text-4xl block mb-4">🚗</span>
          <h3 class="font-semibold text-neutral-900 mb-2">Parking</h3>
          <p class="text-stone-600 text-sm">Free basement parking available. Valet service on weekends.</p>
        </div>
        <div class="text-center p-6">
          <span class="text-4xl block mb-4">♿</span>
          <h3 class="font-semibold text-neutral-900 mb-2">Accessibility</h3>
          <p class="text-stone-600 text-sm">Wheelchair accessible entrance and elevator to all floors.</p>
        </div>
        <div class="text-center p-6">
          <span class="text-4xl block mb-4">🚇</span>
          <h3 class="font-semibold text-neutral-900 mb-2">Nearest Metro</h3>
          <p class="text-stone-600 text-sm">Indiranagar Metro Station - 5 minute walk from Exit A.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>