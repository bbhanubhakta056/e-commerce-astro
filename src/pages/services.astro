---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services } from '../data/services';
---

<BaseLayout 
  title="Our Services - Interior Design & Consultation"
  description="From interior consultation to turnkey solutions, we offer complete interior design services in Bangalore."
>
  
  <!-- Hero -->
  <section class="bg-stone-100 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-neutral-900 mb-4">Our Services</h1>
      <p class="text-stone-600 text-lg max-w-2xl mx-auto">
        Beyond products, we provide complete interior solutions tailored to your needs
      </p>
    </div>
  </section>

  <!-- Services Detail -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
      
      {services.map((service, index) => (
        <div 
          id={service.id}
          class={`flex flex-col ${index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-10 items-center`}
        >
          <!-- Icon Side -->
          <div class="lg:w-1/3 text-center">
            <div class="w-32 h-32 bg-brand-50 rounded-full flex items-center justify-center mx-auto">
              <span class="text-6xl">{service.icon}</span>
            </div>
          </div>

          <!-- Content Side -->
          <div class="lg:w-2/3">
            <span class="text-brand-600 font-medium text-sm uppercase tracking-wider mb-2 block">
              {service.subtitle}
            </span>
            <h2 class="font-serif text-3xl font-bold text-neutral-900 mb-4">{service.title}</h2>
            <p class="text-stone-600 leading-relaxed mb-6">{service.description}</p>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6">
              {service.features.map(feature => (
                <div class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-brand-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-stone-700 text-sm">{feature}</span>
                </div>
              ))}
            </div>

            <div class="flex items-center gap-4">
              <span class="text-sm text-stone-500 bg-stone-100 px-3 py-1 rounded-full">
                {service.pricing}
              </span>
              <a 
                href="/contact" 
                class="inline-flex items-center gap-2 bg-brand-600 text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-brand-700 transition-all"
              >
                {service.cta}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}

    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-brand-600">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h3 class="font-serif text-3xl font-bold text-white mb-4">Not sure which service you need?</h3>
      <p class="text-brand-100 mb-8">Book a free 15-minute call and we'll guide you to the right solution</p>
      <a 
        href="/contact" 
        class="inline-flex items-center gap-2 bg-white text-brand-600 px-8 py-4 rounded-lg font-semibold hover:bg-brand-50 transition-all shadow-lg"
      >
        Schedule Free Call
      </a>
    </div>
  </section>

</BaseLayout>